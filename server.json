{
  "$schema": "https://static.modelcontextprotocol.io/schemas/2025-12-11/server.schema.json",
  "name": "io.github.astrogilda/waitbus",
  "description": "Workstation-local event bus: agents wait on or emit CI/pytest/Docker/filesystem events, no polling.",
  "version": "0.2.0",
  "repository": {
    "url": "https://github.com/astrogilda/waitbus",
    "source": "github"
  },
  "websiteUrl": "https://github.com/astrogilda/waitbus",
  "packages": [
    {
      "registryType": "pypi",
      "identifier": "waitbus",
      "version": "0.2.0",
      "transport": {
        "type": "stdio"
      },
      "runtimeHint": "uvx",
      "runtimeArguments": [
        {
          "type": "positional",
          "value": "waitbus",
          "isRequired": true
        },
        {
          "type": "positional",
          "value": "mcp",
          "isRequired": true
        },
        {
          "type": "positional",
          "value": "serve",
          "isRequired": true
        }
      ]
    }
  ]
}
