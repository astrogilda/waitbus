# lychee ignore list -- one regex per line, matched against each URL.
# Covers local, placeholder, and auth-gated / non-browsable URLs that appear in
# the docs and must never be reported as broken by the report-only link check
# (.github/workflows/lychee.yml).

# --- Local / loopback (not reachable from a CI runner) ---
^https?://localhost
^https?://127\.0\.0\.1
^https?://0\.0\.0\.0

# --- RFC 2606 placeholder domains (example URLs in docs) ---
^https?://([^/]+\.)?example\.com
^https?://([^/]+\.)?example\.org

# --- Auth-gated / non-browsable endpoints ---
# GitHub Actions OIDC token endpoint (referenced in supply-chain docs; returns
# 4xx to an unauthenticated GET, it is not a browsable page).
^https?://token\.actions\.githubusercontent\.com
# GitHub repo settings pages require auth and 302 to login for a CI runner.
^https?://github\.com/[^/]+/[^/]+/settings

# --- Release-please CHANGELOG compare links (tag does not exist until release) ---
# Each release PR's CHANGELOG adds a compare link to the version tag the merge
# will create, so it is necessarily 404 while the PR is open. The tag (and link)
# become valid the moment the release is cut.
^https?://github\.com/[^/]+/[^/]+/compare/[^/]+-v[0-9]

# --- Template / placeholder URLs (unresolved substitution tokens in docs) ---
# GitHub Actions expression placeholders, e.g. https://github.com/${{ ... }}.
\$\{\{
# Shell/template variable placeholders, e.g. https://github.com/${REPO}/...
\$\{[A-Za-z_]
# Angle-bracket version/tag placeholders, e.g. .../release.yml@refs/tags/v<version>.
<[A-Za-z]
# Brace placeholders for runtime-substituted values, e.g. http://127.0.0.1:{port}/metrics.
\{[A-Za-z]

# --- Self raw-main asset referenced by the README (valid only after merge) ---
# README points at docs/architecture.png via an absolute raw URL so the diagram
# renders on PyPI; on a PR that URL 404s until the image lands on main.
^https?://raw\.githubusercontent\.com/[^/]+/waitbus/main/docs/architecture\.png
